{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SidecarResult",
  "description": "Schema for an OpenCode sidecar task result package",
  "type": "object",
  "required": [
    "task_id",
    "worker",
    "model",
    "status",
    "confidence",
    "summary"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Task identifier matching the task envelope"
    },
    "worker": {
      "type": "string",
      "enum": [
        "sidecar-explorer",
        "sidecar-reviewer",
        "sidecar-log-analyst",
        "sidecar-implementer",
        "sidecar-test-fixer"
      ],
      "description": "Worker agent name (matches the opencode/agents/*.md file name)"
    },
    "model": {
      "type": "string",
      "description": "Model that executed the task"
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed", "partial", "blocked"],
      "description": "Task completion status"
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Worker's confidence in its findings"
    },
    "summary": {
      "type": "string",
      "description": "Brief summary of the result"
    },
    "contract_status": {
      "type": "string",
      "enum": ["structured", "fallback"],
      "description": "Whether result.json came from a parseable worker JSON block or was synthesized from prose"
    },
    "capability_audit": {
      "type": "object",
      "description": "Post-run audit of tools and inherited capabilities actually used by the worker",
      "properties": {
        "tools_used": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mcp_tools_used": {
          "type": "array",
          "items": { "type": "string" }
        },
        "write_tools_used": {
          "type": "array",
          "items": { "type": "string" }
        },
        "web_access": {
          "type": "boolean"
        },
        "internal_artifacts_read": {
          "type": "boolean"
        },
        "internal_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "policy_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "title"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "title": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "file": { "type": "string" },
                "lines": { "type": "string" },
                "reason": { "type": "string" }
              }
            }
          },
          "recommendation": { "type": "string" }
        }
      }
    },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "commands_run": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tests_run": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "uncertainties": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requires_main_agent_decision": {
      "type": "boolean"
    }
  }
}
